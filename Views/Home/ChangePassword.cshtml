@{
ViewData["Title"] = "ChangePassword";
}

@model ChangePasswordViewModel

<div>
    @if (TempData["SuccessMessage"] != null)
    {
    <div class="alert alert-success" role="alert">
        @TempData["SuccessMessage"]
    </div>
    }

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <form asp-controller="Home" asp-action="ChangePassword" method="post">
        <div class="row mb-3">
            <label for="OldPassword" class="col-sm-2 col-form-label" asp-for="OldPassword">Old Password:</label>
            <div class="col-sm-10">
                <input asp-for="OldPassword" class="form-control">
                <span asp-validation-for="OldPassword" class="text-danger"></span>
            </div>
        </div>
        
        <div class="row mb-3">
            <label for="NewPassword" class="col-sm-2 col-form-label" asp-for="NewPassword">New Password:</label>
            <div class="col-sm-10">
                <input asp-for="NewPassword" class="form-control">
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>
        </div>

        <div class="row mb-3">
            <label for="ConfirmNewPassword" class="col-sm-2 col-form-label" asp-for="ConfirmNewPassword">New Password Again:</label>
            <div class="col-sm-10">
                <input asp-for="ConfirmNewPassword" class="form-control">
                <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
            </div>
        </div>

        <button type="submit" class="btn btn-primary">Change Password!</button>
    </form>
</div>

